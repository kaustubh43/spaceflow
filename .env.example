# Copy to .env before running `docker compose up`
# Postgres
POSTGRES_USER=idesigner
POSTGRES_PASSWORD=idesigner_dev_password
POSTGRES_DB=idesigner

# Backend
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
# DATABASE_URL is assembled in docker-compose from the POSTGRES_* vars

# Seed a demo designer + sample project on first boot
SEED_DEMO=true
DEMO_EMAIL=designer@idesigner.app
DEMO_PASSWORD=demo1234

# Frontend (build/runtime)
VITE_API_URL=http://localhost:8000
